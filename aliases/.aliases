# --- podstawowe aliasy ---
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'

alias ..='cd ..'
alias ...='cd ../..'
alias -- -='cd -'

alias c='clear'
alias h='history 0 | grep'
alias reload='source ~/.zshrc'
alias path='echo $PATH | tr ":" "\n"'

# --- IP ---
alias myip_public='curl ifconfig.me'

# --- bezpieczne operacje ---
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias mkdir='mkdir -pv'

# --- katalogi i edycja ---
alias md='mkdir -p'
alias rd='rmdir'
alias e='$EDITOR'

# --- git ---
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gca='git commit --amend --no-edit'
alias gp='git push'
alias gpfl='git push --force-with-lease'
alias gl='git pull'
alias gd='git diff'
alias gds='git diff --staged'
alias gb='git branch'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gcom='git checkout main'
alias glog='git log --oneline --graph --decorate -20'

# --- system-specific ---
case "$OSTYPE" in
  darwin*)
    [ -f "$HOME/.aliases_mac" ] && source "$HOME/.aliases_mac"
    ;;
  linux*)
    [ -f "$HOME/.aliases_linux" ] && source "$HOME/.aliases_linux"
    ;;
esac
